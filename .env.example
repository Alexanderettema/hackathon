# ── OpenAI ───────────────────────────────────────────────────────────────
# If left blank, the server looks for ../hackathon/.env, then runs in MOCK mode.
OPENAI_API_KEY=
# Fallback model used when a ladder model is unavailable for your key.
OPENAI_MODEL=gpt-4o-mini

# ── Networking ───────────────────────────────────────────────────────────
# Player server — this is the port your cloudflared tunnel must forward.
PLAYER_PORT=8000
# Admin server — bound to 127.0.0.1 only, never exposed through the tunnel.
ADMIN_PORT=8766

# Public URL of your tunnel (optional). Used to render the join QR / share link.
# Leave blank to auto-read ../hackathon/data/tunnel.url if present.
PUBLIC_URL=
